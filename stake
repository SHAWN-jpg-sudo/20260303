#include <iostream>
#include <stack>
using namespace std;

// 顯示 stack 內容（由上到下）
void showStack(stack<int> s) {
    if (s.empty()) {
        cout << "Stack 是空的" << endl;
        return;
    }

    cout << "目前 Stack 內容 (由上到下): ";

    // 用複製的 stack 來輸出
    while (!s.empty()) {
        cout << s.top() << " ";
        s.pop();
    }
    cout << endl;
}

int main() {
    stack<int> s;
    int choice, value;

    while (true) {
        cout << "\n請選擇操作：" << endl;
        cout << "1 → Push (加入)" << endl;
        cout << "2 → Pop (移除)" << endl;
        cout << "0 → 結束" << endl;
        cout << "輸入: ";
        cin >> choice;

        if (choice == 1) {
            cout << "請輸入要加入的數字: ";
            cin >> value;
            s.push(value);
            cout << "已加入: " << value << endl;

        } else if (choice == 2) {
            if (s.empty()) {
                cout << "Stack 是空的，無法移除" << endl;
            } else {
                cout << "移除: " << s.top() << endl;
                s.pop();
            }

        } else if (choice == 0) {
            cout << "程式結束" << endl;
            break;

        } else {
            cout << "輸入錯誤，請重新輸入" << endl;
        }

        // 每次操作後顯示 stack
        showStack(s);
    }

	cout<<"O(5) + O(5) = O(10)"<<endl;
	cout<<"O(1)";
	
    return 0;
}
