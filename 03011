#include <iostream>
#include <ctime>
#include <cstdlib>

using namespace std;

void printArray(int arr[], int n)
{
    for(int i=0;i<n;i++)
        cout<<arr[i]<<" ";
    cout<<endl;
}

////////////////////////
// Bubble Sort Steps
////////////////////////
void bubbleSortSteps(int arr[], int n)
{
    cout<<"\nBubble Sort Steps:\n";

    for(int i=0;i<n-1;i++)
    {
        for(int j=0;j<n-i-1;j++)
        {
            if(arr[j]>arr[j+1])
                swap(arr[j],arr[j+1]);
        }

        cout<<"Pass "<<i+1<<": ";
        printArray(arr,n);
    }
}

////////////////////////
// Insertion Sort Steps
////////////////////////
void insertionSortSteps(int arr[], int n)
{
    cout<<"\nInsertion Sort Steps:\n";

    for(int i=1;i<n;i++)
    {
        int key=arr[i];
        int j=i-1;

        while(j>=0 && arr[j]>key)
        {
            arr[j+1]=arr[j];
            j--;
        }

        arr[j+1]=key;

        cout<<"Step "<<i<<": ";
        printArray(arr,n);
    }
}

////////////////////////
// Quick Sort
////////////////////////
int partition(int arr[], int low, int high)
{
    int pivot=arr[high];
    int i=low-1;

    for(int j=low;j<high;j++)
    {
        if(arr[j]<pivot)
        {
            i++;
            swap(arr[i],arr[j]);
        }
    }

    swap(arr[i+1],arr[high]);

    return i+1;
}

void quickSort(int arr[], int low, int high)
{
    if(low<high)
    {
        int pi=partition(arr,low,high);

        quickSort(arr,low,pi-1);
        quickSort(arr,pi+1,high);
    }
}

////////////////////////
// Merge Sort
////////////////////////
void merge(int arr[], int l, int m, int r)
{
    int i=l,j=m+1,k=0;
    int temp[100];

    while(i<=m && j<=r)
    {
        if(arr[i]<arr[j])
            temp[k++]=arr[i++];
        else
            temp[k++]=arr[j++];
    }

    while(i<=m) temp[k++]=arr[i++];
    while(j<=r) temp[k++]=arr[j++];

    for(i=l,k=0;i<=r;i++,k++)
        arr[i]=temp[k];
}

void mergeSort(int arr[], int l, int r)
{
    if(l<r)
    {
        int m=(l+r)/2;

        mergeSort(arr,l,m);
        mergeSort(arr,m+1,r);

        merge(arr,l,m,r);
    }
}

////////////////////////
// Main
////////////////////////
int main()
{
    int demo[]={5,3,8,4,2};
    int n=5;

    cout<<"Original Array:\n";
    printArray(demo,n);

    int a[5],b[5],c[5],d[5];

    for(int i=0;i<n;i++)
    {
        a[i]=b[i]=c[i]=d[i]=demo[i];
    }

    bubbleSortSteps(a,n);
    insertionSortSteps(b,n);

    cout<<"\nMerge Sort Result:\n";
    mergeSort(c,0,n-1);
    printArray(c,n);

    cout<<"\nQuick Sort Result:\n";
    quickSort(d,0,n-1);
    printArray(d,n);

    ///////////////////////////
    // Time Complexity Test
    ///////////////////////////

    cout<<"\n\n===== Time Test =====\n";

    int size=5000;

    int arr1[size],arr2[size],arr3[size],arr4[size];

    for(int i=0;i<size;i++)
    {
        int num=rand()%10000;
        arr1[i]=arr2[i]=arr3[i]=arr4[i]=num;
    }

    clock_t start,end;

    start=clock();
    for(int i=0;i<size-1;i++)
        for(int j=0;j<size-i-1;j++)
            if(arr1[j]>arr1[j+1])
                swap(arr1[j],arr1[j+1]);
    end=clock();

    cout<<"Bubble Sort Time: "<<(double)(end-start)/CLOCKS_PER_SEC<<" sec\n";

    start=clock();
    for(int i=1;i<size;i++)
    {
        int key=arr2[i];
        int j=i-1;
        while(j>=0 && arr2[j]>key)
        {
            arr2[j+1]=arr2[j];
            j--;
        }
        arr2[j+1]=key;
    }
    end=clock();

    cout<<"Insertion Sort Time: "<<(double)(end-start)/CLOCKS_PER_SEC<<" sec\n";

    start=clock();
    mergeSort(arr3,0,size-1);
    end=clock();

    cout<<"Merge Sort Time: "<<(double)(end-start)/CLOCKS_PER_SEC<<" sec\n";

    start=clock();
    quickSort(arr4,0,size-1);
    end=clock();

    cout<<"Quick Sort Time: "<<(double)(end-start)/CLOCKS_PER_SEC<<" sec\n";

    return 0;
}
